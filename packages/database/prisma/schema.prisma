generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ─────────────────────────────────────────────────────────────────────

enum UserRole {
  CUSTOMER
  ADMIN
  SELLER
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  name         String
  passwordHash String
  roles        UserRole[] @default([CUSTOMER])
  refreshTokens RefreshToken[]
  orders       Order[]
  payments     Payment[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ─── Product ──────────────────────────────────────────────────────────────────

enum ProductStatus {
  ACTIVE
  INACTIVE
  DRAFT
}

model Product {
  id          String        @id @default(uuid())
  name        String
  description String        @db.Text
  price       Decimal       @db.Decimal(10, 2)
  stock       Int           @default(0)
  sellerId    String
  status      ProductStatus @default(DRAFT)
  imageUrls   String[]
  tags        String[]
  orderItems  OrderItem[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([sellerId])
  @@index([status])
  @@map("products")
}

// ─── Order ────────────────────────────────────────────────────────────────────

enum OrderStatus {
  PENDING
  PAYMENT_PROCESSING
  PAYMENT_FAILED
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

model Order {
  id              String      @id @default(uuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  items           OrderItem[]
  status          OrderStatus @default(PENDING)
  totalAmount     Decimal     @db.Decimal(10, 2)
  shippingLine1   String
  shippingLine2   String?
  shippingCity    String
  shippingState   String
  shippingPostal  String
  shippingCountry String      @db.Char(2)
  payments        Payment[]
  // Event sourcing: every state transition is recorded
  events          OrderEvent[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([userId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  name      String  // snapshot at time of order

  @@index([orderId])
  @@map("order_items")
}

// Event store for CQRS — append-only log of every order state change
model OrderEvent {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  eventType   String
  payload     Json
  correlationId String?
  createdAt   DateTime @default(now())

  @@index([orderId])
  @@map("order_events")
}

// ─── Payment ──────────────────────────────────────────────────────────────────

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
}

model Payment {
  id                    String        @id @default(uuid())
  orderId               String
  order                 Order         @relation(fields: [orderId], references: [id])
  userId                String
  user                  User          @relation(fields: [userId], references: [id])
  amount                Decimal       @db.Decimal(10, 2)
  currency              String        @default("INR") @db.Char(3)
  status                PaymentStatus @default(PENDING)
  stripePaymentIntentId String?       @unique
  idempotencyKey        String        @unique @default(uuid())
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([orderId])
  @@index([userId])
  @@map("payments")
}
